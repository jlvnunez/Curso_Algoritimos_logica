Algoritmo "contador"
// Disciplina   : [Linguagem e Lógica de Programaçăo]
// Professor   : Antonio Carlos Nicolodi 
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 29/04/2026
Var
   valor,contador,salto:Inteiro

Inicio
      contador <- 0
      Escreva("Quer quantos passos? ")
      Leia(valor)
      Escreva("Qual será o valor do salto? ")
      Leia(salto)
      Enquanto (contador <= valor)faca
          Escreva(contador)
          contador <- contador + salto
      FimEnquanto


Fimalgoritmo