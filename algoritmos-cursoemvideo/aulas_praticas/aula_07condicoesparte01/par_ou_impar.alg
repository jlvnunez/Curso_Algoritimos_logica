algoritmo "ParouImpar"
// Função :
// Autor :
// Data : 28/04/2026
// Seção de Declarações 
var
   n:Inteiro

inicio
      Escreva("Digite um Numero ")
      Leia(n)
      Se (n%2 =0)entao
         Escreva("O Numero ",n," é PAR")
      senao
         Escreva("O Numero ",n, " é IMPAR")
      FimSe
// Seção de Comandos 
fimalgoritmo
