algoritmo "creusa01"
// Funçăo :
// Autor :
// Data : 27/04/2026
// Seçăo de Declaraçőes 
var
   ano_atual,ano_nasc,idade:Inteiro
   
inicio
      Escreva("Em que ano nos estamos? ")
      leia(ano_atual)
      Escreva("Em que ano eu nasci? ")
      leia(ano_nasc)
      idade<- ano_atual - ano_nasc
      Escreva("Minha idade será" ,idade)

// Seçăo de Comandos 
fimalgoritmo
