algoritmo "creusa04"
// Função :
// Autor :
// Data : 27/04/2026
// Seção de Declarações 
var
   preco,imposto:Real

inicio
      Escreva("Qual o valor do produto?US$ ")
      leia(preco)
      imposto<- (preco*60)/100
      Escreva("O imposto será de US$ ",imposto:5:2," dolares")
// Seção de Comandos 
fimalgoritmo
